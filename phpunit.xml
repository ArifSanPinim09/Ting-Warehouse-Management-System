<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
        <testsuite name="Browser">
            <directory>tests/Browser</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <!-- PENTING: <env force> + <server> harus DIPASANGKAN.
             Shell bisa ter-polusi variabel dari .env (APP_ENV=local, DB_*=mysql).
             - <env force="true"> menimpa getenv()/$_ENV, tapi TIDAK menyentuh $_SERVER
             - <server> menulis $_SERVER secara unconditional
             Laravel (phpdotenv) membaca $_SERVER lebih dulu → tanpa <server>,
             nilai 'local' dari shell menang → test berjalan di MySQL dev
             (RefreshDatabase = migrate:fresh MENGHAPUS data dev!) dan makro
             testing Livewire tidak terdaftar (butuh APP_ENV=testing). -->
        <env name="APP_ENV" value="testing" force="true"/>
        <server name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file" force="true"/>
        <server name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4" force="true"/>
        <server name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null" force="true"/>
        <server name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array" force="true"/>
        <server name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite" force="true"/>
        <server name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:" force="true"/>
        <server name="DB_DATABASE" value=":memory:"/>
        <env name="DB_URL" value="" force="true"/>
        <server name="DB_URL" value=""/>
        <env name="MAIL_MAILER" value="array" force="true"/>
        <server name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync" force="true"/>
        <server name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array" force="true"/>
        <server name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false" force="true"/>
        <server name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false" force="true"/>
        <server name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false" force="true"/>
        <server name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
